# Пример переменных окружения
#
# Скопируйте файл и подставьте свои значения:
#   cp .env.example .env
#
# AnDocGen не читает .env автоматически — переменные должны быть в окружении процесса.
#
# Загрузка перед запуском (bash/zsh):
#   set -a && source .env && set +a
#   andocgen ./examples/mini_calculator --config config.yaml
#
# Или экспорт в текущую сессию:
#   export OPENAI_API_KEY="your-key-here"
#   andocgen ./examples/mini_calculator --config config.yaml

OPENAI_API_KEY=sk-your-api-key-here
