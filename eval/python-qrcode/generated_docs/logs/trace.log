        self.color_mask = kwargs.get("color_mask", SolidFillColorMask())

        if kwargs.get("embeded_image_path") or kwargs.get("embeded_image"):
            warnings.warn(
                "The 'embeded_*' parameters are deprecated. Use 'embedded_image_path' "
