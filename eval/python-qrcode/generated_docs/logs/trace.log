```python
        difference = len(self) - len(other)
        if difference < 0:
            return self

        if self[0] == 0:
            num = list(self[1:])
            if difference:
                num.append(0)
            return Polynomial(num, 0) % other

        ratio = glog(self[0]) - glog(other[0])

        num = [
            item ^ gexp(glog(other_item) + ratio)
            for item, other_item in zip(self, other, strict=False)
        ]
        if difference:
            num.extend(self[-difference:])

        # recursive call
        return Polynomial(num, 0) % other
```

